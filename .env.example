# Google OAuth 2.0 client ID (Web application) for Sign in with Google
# Create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000
GOOGLE_CLIENT_ID=

# AWS Cognito (Amazon Cognito User Pool + app client with Hosted UI)
# Create at https://console.aws.amazon.com/cognito/
AWS_REGION=ap-southeast-2
AWS_USER_POOL_ID=
AWS_USER_POOL_CLIENT_ID=
# Hosted UI domain, e.g. your-app.auth.ap-southeast-2.amazoncognito.com
AWS_COGNITO_DOMAIN=
# Must match an allowed callback URL on the Cognito app client
AWS_REDIRECT_SIGN_IN=http://localhost:3000/
AWS_REDIRECT_SIGN_OUT=http://localhost:3000/
